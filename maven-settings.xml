<?xml version="1.0" encoding="UTF-8"?>
<settings xmlns="http://maven.apache.org/SETTINGS/1.0.0"
          xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
          xsi:schemaLocation="http://maven.apache.org/SETTINGS/1.0.0 http://maven.apache.org/xsd/settings-1.0.0.xsd">

    <mirrors>
        <!-- Maven Central → 阿里云 -->
        <mirror>
            <id>aliyun-public</id>
            <mirrorOf>central</mirrorOf>
            <name>Aliyun Maven Central</name>
            <url>https://maven.aliyun.com/repository/public</url>
        </mirror>
        <!-- Spring release/milestone/snapshot → 阿里云 -->
        <mirror>
            <id>aliyun-spring</id>
            <mirrorOf>spring-release,spring-milestones,spring-snapshots</mirrorOf>
            <name>Aliyun Spring</name>
            <url>https://maven.aliyun.com/repository/spring</url>
        </mirror>
        <!-- Google → 阿里云 -->
        <mirror>
            <id>aliyun-google</id>
            <mirrorOf>google-maven-central</mirrorOf>
            <name>Aliyun Google</name>
            <url>https://maven.aliyun.com/repository/google</url>
        </mirror>
        <!-- Gradle plugin → 阿里云 -->
        <mirror>
            <id>aliyun-gradle</id>
            <mirrorOf>gradle-plugins</mirrorOf>
            <name>Aliyun Gradle Plugin</name>
            <url>https://maven.aliyun.com/repository/gradle-plugin</url>
        </mirror>
        <!-- 其他所有仓库 → 华为云兜底 -->
        <mirror>
            <id>huawei</id>
            <mirrorOf>*</mirrorOf>
            <name>Huawei Cloud (catch-all)</name>
            <url>https://mirrors.huaweicloud.com/repository/maven</url>
        </mirror>
    </mirrors>

</settings>
